<?xml version="1.0" encoding="utf-8"?>
<!-- Clean UTF-8 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/call_background"
    android:padding="32dp">

    <!-- Top bar with settings button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginBottom="16dp">

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_preferences"
            android:contentDescription="Настройки"
            android:tint="@android:color/white"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Avatar circle -->
    <LinearLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_avatar_circle"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📞"
            android:textSize="48sp" />
    </LinearLayout>

    <!-- Remote IP / name -->
    <TextView
        android:id="@+id/tvRemoteIp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="192.168.1.1"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Звонок активен"
        android:textColor="#AAFFFFFF"
        android:textSize="14sp"
        android:layout_marginTop="4dp" />

    <!-- Connection quality indicator -->
    <TextView
        android:id="@+id/tvConnectionQuality"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📶 Отлично"
        android:textColor="#4CAF50"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        android:visibility="visible" />

    <!-- Call Timer -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="@android:color/white"
        android:textSize="40sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:layout_marginTop="32dp" />

    <!-- Divider -->
    <View
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:background="#44FFFFFF"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp" />

    <!-- Controls row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">

        <!-- Mute button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMute"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:text="Выкл. микрофон"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            app:strokeColor="@android:color/white"
            app:strokeWidth="2dp"
            app:cornerRadius="32dp"
            app:icon="@drawable/ic_mic"
            app:iconGravity="textStart"
            app:iconTint="@android:color/white" />

        <!-- End call button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEndCall"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Завершить"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            app:backgroundTint="@color/end_call_red"
            app:cornerRadius="32dp"
            app:icon="@android:drawable/ic_menu_close_clear_cancel"
            app:iconGravity="textStart"
            app:iconTint="@android:color/white" />
    </LinearLayout>

</LinearLayout>
